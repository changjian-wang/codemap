# Sources & build inputs — not needed at runtime
src/**
test/**
eval/**
docs/plan/**
docs/adrs/**
docs/media/**
# NOTE: docs/mockups/** MUST ship — panel.ts (renderHtml) reads
# docs/mockups/lumen-backend-v3.html at runtime to produce the
# Workspace view. Excluding it here in 0.0.4 silently broke the panel
# ("Mockup file not found"). The 118 KB is worth a working webview.
.vscode/**
.vscode-test/**
.github/**
node_modules/**

# Build / tool config
esbuild.js
tsconfig.json
vitest.config.ts
.gitignore
.eslintrc*
.prettierrc*

# Test artifacts
coverage/**
*.log

# Source maps (the runtime bundle ships, but we don't need raw maps in the .vsix)
dist/**/*.map

# Source icon (PNG ships, SVG stays in repo only)
media/*.svg

# Misc
**/.DS_Store
**/Thumbs.db
