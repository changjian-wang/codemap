# Sources & build inputs — not needed at runtime
src/**
test/**
eval/**
legacy/**
docs/**
tools/**
.vscode/**
.vscode-test/**
.github/**
node_modules/**

# Build / tool config
esbuild.js
tsconfig.json
vitest.config.ts
.gitignore
.eslintrc*
.prettierrc*

# Test artifacts
coverage/**
*.log

# Source maps (the runtime bundle ships, but we don't need raw maps in the .vsix)
dist/**/*.map

# Source icon (PNG ships, SVG stays in repo only)
media/*.svg

# Misc
**/.DS_Store
**/Thumbs.db
